@using Microsoft.Extensions.Options
@using ASC.Web.Configuration
@inject IOptions<ApplicationSettings> _configurationSettings

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@_configurationSettings.Value.ApplicationTitle</title>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <link href="~/css/materialize.css" rel="stylesheet" />
    <link href="~/css/styles.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="white" role="navigation">
            <div class="nav-wrapper container">
                <a id="logo-container" href="/Identity/Account/Login" class="brand-logo">
                    <img class="responsive-img" src="~/images/logo.png" alt="Logo" />
                </a>

                <ul class="right hide-on-med-and-down">
                    <li><a href="/Identity/Account/Login" class="teal-text text-darken-4">Login</a></li>
                    <li><a href="#" class="teal-text text-darken-4">Contact</a></li>
                </ul>

                <ul id="nav-mobile" class="sidenav">
                    <li><a href="/Identity/Account/Login">Login</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>

                <a href="#" data-target="nav-mobile" class="sidenav-trigger">
                    <i class="material-icons">menu</i>
                </a>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/materialize.min.js"></script>
    <script src="~/js/init.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>